# Environment Configuration Template
# Copy to .env in the /api folder and fill in your actual values

# ============================================
# Azure OpenAI Configuration
# ============================================

# Your Azure OpenAI endpoint (e.g., https://myresource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/

# Your Azure OpenAI API key
AZURE_OPENAI_KEY=your-openai-api-key-here

# The deployment name of your model (e.g., gpt-4.1-mini, gpt-4o-mini, chat-model)
AZURE_OPENAI_DEPLOYMENT_ID=<your-deployment-name>  # e.g. gpt-4.1-mini

# ============================================
# Azure Search Configuration
# ============================================

# Your Azure AI Search endpoint (e.g., https://myservice.search.windows.net)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net

# Your Azure AI Search admin key
AZURE_SEARCH_KEY=your-search-admin-key-here

# The name of your search index (e.g., documents, knowledge-base)
AZURE_SEARCH_INDEX=documents

# ============================================
# Optional Configuration
# ============================================

# Node environment (development, production)
NODE_ENV=development

# Enable debug logging
DEBUG=false

# Number of search results to return (default: 3)
SEARCH_TOP_RESULTS=3

# Chat model parameters
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1000
